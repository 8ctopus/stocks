{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "dev 9001",
        "type": "php",
        "request": "launch",
        "port": 9001,
        "log": true,
        "stopOnEntry": false,
        "pathMappings":
        {
          "/var/www/site/": "${workspaceRoot}"
        },
      },
      {
        "name": "Launch",
        "request": "launch",
        "type": "php",
        "program": "${file}",
        "cwd": "${workspaceRoot}",
        "externalConsole": false
      }
    ]
  }